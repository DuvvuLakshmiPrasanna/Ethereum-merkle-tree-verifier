# Ethereum JSON-RPC endpoint
# Get a free key from Alchemy: https://www.alchemy.com/
# or Infura: https://www.infura.io/
#
# Alchemy example:
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
#
# Infura example:
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
#
# NEVER commit your actual API key — only this .env.example file
